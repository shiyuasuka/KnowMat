# =============================================================================
# KnowMat 环境变量模板 → 复制为 `.env` 后填写真实值
# =============================================================================
#
# PP-StructureV3 表格/公式精修由代码强制开启（忽略 KNOWMAT_SKIP_PPSTRUCTURE_REFINE）。
# 化学式裁剪重 OCR 仍可用 KNOWMAT_SKIP_CHEM_REOCR 关闭以省显存。
#

# --- LLM（OpenAI 兼容 / 千帆等）---
LLM_API_KEY="your-llm-api-key-here"
LLM_BASE_URL="https://your-llm-endpoint.example.com/v2"
LLM_MODEL="your-default-model-name"

# --- PaddleOCR-VL ---
PADDLEOCRVL_MODEL_DIR="models/paddleocrvl1_5"
PADDLEOCRVL_VERSION="1.5"
PADDLE_PDX_CACHE_HOME="models/paddleocrvl1_5"
# 仅排错时用 CPU；正常留空以使用 GPU（多 PDF 后若 VL 报错可显式写 gpu:0）
# KNOWMAT_OCR_DEVICE="cpu"
# 仅紧急调试：VL 不可用时允许降级到传统行 OCR（仍跑 PP-StructureV3 精修，无 VL restructure）
# KNOWMAT_ALLOW_LEGACY_PADDLEOCR="1"
# 默认跳过 VL 的 engine.close()，避免多 PDF 连续跑时下一本出现 Place(undefined:0)；需激进释放原生资源时再开
# KNOWMAT_PADDLEOCR_VL_EXPLICIT_CLOSE="1"

# --- OCR：质量优先（推荐起点，精修链条完整）---
# OCR_RENDER_DPI：300 为 README 默认，细字/公式/表格更稳；200 省显存但略损细节
OCR_RENDER_DPI="300"
# OCR_BATCH_SIZE：2 为 VL 批推理默认；8GB 若 CUDA OOM 再改为 1
OCR_BATCH_SIZE="2"
# 长 PDF 分段释放显存，不关闭精修；0=不分段（短文档可关）
# OCR_PAGES_PER_RELEASE="4"
OCR_MAX_RENDER_WORKERS="4"
OMP_NUM_THREADS="1"

# 低置信度：统计用阈值；精修后仍可疑的正文可用 tag 提醒下游（默认 none 不改行为）
OCR_LOW_CONFIDENCE_THRESHOLD="0.5"
# KNOWMAT_OCR_LOW_CONF_ACTION="none"
# KNOWMAT_OCR_LOW_CONF_ACTION="tag"

# 单次推理防挂死（秒），0=关闭；超时无法杀掉 CUDA 内核，仅避免进程无限等待
# OCR_INFER_TIMEOUT_SEC="0"

# --- 仅当显存不足且可接受效果下降时：可跳过化学式重 OCR（StructureV3 仍会运行）---
# KNOWMAT_SKIP_CHEM_REOCR="true"
# 仍 OOM 时的顺序建议：OCR_BATCH_SIZE=1 → OCR_RENDER_DPI=200 → OCR_PAGES_PER_RELEASE=4

# --- 调试 / 部分页 / 缓存 ---
# KNOWMAT_OCR_PAGES="1-10"
# KNOWMAT_OCR_SKIP_CACHED="1"
# KNOWMAT_OCR_NO_CACHE_WRITE="1"

# --- KnowMat 行为 ---
KNOWMAT2_TRIM_REFERENCES_SECTION="false"

# --- LangSmith（可选）---
LANGCHAIN_API_KEY="your-langsmith-api-key"
LANGCHAIN_TRACING_V2="false"

#
# IMPORTANT: Never commit the real `.env` file or API keys to git.
#
