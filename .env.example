# =============================================================================
# KnowMat environment template
# =============================================================================
#
# PP-StructureV3 table/formula refinement is enabled by code.
# Chemical formula crop re-OCR can still be disabled with KNOWMAT_SKIP_CHEM_REOCR.
#

# --- LLM (OpenAI-compatible endpoint) ---
LLM_API_KEY="your-llm-api-key-here"
LLM_BASE_URL="https://your-llm-endpoint.example.com/v2"
LLM_MODEL="your-default-model-name"

# --- PaddleOCR-VL ---
PADDLEOCRVL_MODEL_DIR="models/paddleocrvl1_5"
PADDLEOCRVL_VERSION="1.5"
PADDLE_PDX_CACHE_HOME="models/paddleocrvl1_5"
# Auto mode: use GPU when CUDA-enabled Paddle is available, otherwise CPU.
# To require GPU and fail fast if Paddle has fallen back to CPU, set:
# KNOWMAT_OCR_DEVICE="gpu:0"
# For emergency debugging only: allow fallback to legacy PaddleOCR.
# KNOWMAT_ALLOW_LEGACY_PADDLEOCR="1"
# Skip explicit VL engine.close() by default to avoid Place(undefined:0) after many PDFs.
# KNOWMAT_PADDLEOCR_VL_EXPLICIT_CLOSE="1"

# --- OCR quality-first defaults ---
# Quoted values must have matching quotes or KnowMat will fail fast at startup.
OCR_RENDER_DPI="300"
# VL batch size. Use 1 on smaller GPUs if you hit CUDA OOM.
OCR_BATCH_SIZE="2"
# Release GPU memory every N pages for long PDFs. Leave commented to disable.
# OCR_PAGES_PER_RELEASE="4"
OCR_MAX_RENDER_WORKERS="4"
OMP_NUM_THREADS="1"

# Low-confidence reporting
OCR_LOW_CONFIDENCE_THRESHOLD="0.5"
# KNOWMAT_OCR_LOW_CONF_ACTION="none"
# KNOWMAT_OCR_LOW_CONF_ACTION="tag"

# Single inference wait timeout in seconds. 0 disables it.
# OCR_INFER_TIMEOUT_SEC="0"

# Optional memory-saving switch: skip chemical formula crop re-OCR.
# KNOWMAT_SKIP_CHEM_REOCR="true"
# OOM tuning order: OCR_BATCH_SIZE=1 -> OCR_RENDER_DPI=200 -> OCR_PAGES_PER_RELEASE=4

# --- Debugging / partial pages / cache ---
# KNOWMAT_OCR_PAGES="1-10"
# KNOWMAT_OCR_SKIP_CACHED="1"
# KNOWMAT_OCR_NO_CACHE_WRITE="1"

# --- KnowMat behavior ---
KNOWMAT2_TRIM_REFERENCES_SECTION="false"

# --- LangSmith (optional) ---
LANGCHAIN_API_KEY="your-langsmith-api-key"
LANGCHAIN_TRACING_V2="false"

#
# IMPORTANT: Never commit the real `.env` file or API keys to git.
#
